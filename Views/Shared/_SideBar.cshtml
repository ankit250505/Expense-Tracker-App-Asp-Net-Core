@using System.Security.Claims
@{
    var fullName = User.Claims.FirstOrDefault(c => c.Type == "FullName")?.Value
                  ?? User.Identity?.Name ?? "User";
    var profileImage = User.Claims.FirstOrDefault(c => c.Type == "ProfileImage")?.Value;
    var currentPath = Context.Request.Path.Value?.ToLower() ?? "";
    string ActiveIf(string path) =>
        (path == "/" ? currentPath == "/" : currentPath.StartsWith(path.ToLower()))
        ? "active" : "";
}

<style>
    /* ═══════════════════════════════════════════════════════════
       SIDEBAR  –  SpendSense
       ═══════════════════════════════════════════════════════════ */

    #ss-sidebar {
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        width: 260px;
        background: #0d1419;
        border-right: 1px solid rgba(255,255,255,0.07);
        display: flex;
        flex-direction: column;
        z-index: 900;
        transition: width .28s cubic-bezier(.4,0,.2,1);
        overflow: hidden;
    }

        #ss-sidebar.docked {
            width: 68px;
        }

    /* Logo row */
    .ss-logo-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 20px 16px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        min-height: 64px;
        flex-shrink: 0;
    }

    .ss-logo {
        font-family: 'Syne', sans-serif;
        font-size: 1.25rem;
        font-weight: 800;
        letter-spacing: -.02em;
        color: #e8f0e9;
        text-decoration: none;
        white-space: nowrap;
        transition: opacity .2s;
        overflow: hidden;
    }

        .ss-logo span {
            color: #4ade80;
        }

    #ss-sidebar.docked .ss-logo {
        opacity: 0;
        width: 0;
        pointer-events: none;
    }

    .ss-toggle {
        background: none;
        border: none;
        cursor: pointer;
        color: #7a9180;
        width: 34px;
        height: 34px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        font-size: 1rem;
        transition: color .2s, background .2s;
        flex-shrink: 0;
    }

        .ss-toggle:hover {
            color: #e8f0e9;
            background: rgba(255,255,255,0.05);
        }

    /* Profile */
    .ss-profile {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-bottom: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
        overflow: hidden;
    }

    .ss-avatar {
        width: 38px;
        height: 38px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid rgba(74,222,128,0.3);
        flex-shrink: 0;
    }

    .ss-profile-info {
        overflow: hidden;
        white-space: nowrap;
        transition: opacity .2s, max-width .2s;
        max-width: 180px;
    }

    #ss-sidebar.docked .ss-profile-info {
        opacity: 0;
        max-width: 0;
    }

    .ss-profile-name {
        font-family: 'Syne', sans-serif;
        font-size: .88rem;
        font-weight: 700;
        color: #e8f0e9;
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .ss-profile-role {
        font-size: .75rem;
        color: #7a9180;
        display: block;
    }

    /* Nav */
    .ss-nav {
        flex: 1;
        overflow-y: auto;
        overflow-x: hidden;
        padding: 12px 8px;
        scrollbar-width: thin;
        scrollbar-color: rgba(255,255,255,0.08) transparent;
    }

    .ss-section-label {
        font-family: 'Syne', sans-serif;
        font-size: .65rem;
        font-weight: 700;
        letter-spacing: .1em;
        text-transform: uppercase;
        color: #7a9180;
        padding: 10px 10px 6px;
        white-space: nowrap;
        overflow: hidden;
        transition: opacity .2s;
        display: block;
    }

    #ss-sidebar.docked .ss-section-label {
        opacity: 0;
    }

    .ss-nav-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        text-decoration: none;
        color: #7a9180;
        font-family: 'DM Sans', sans-serif;
        font-size: .9rem;
        font-weight: 500;
        white-space: nowrap;
        transition: background .18s, color .18s;
        position: relative;
        margin-bottom: 2px;
        border: 1px solid transparent;
    }

        .ss-nav-item:hover {
            color: #e8f0e9;
            background: rgba(255,255,255,0.05);
            text-decoration: none;
        }

        .ss-nav-item.active {
            color: #4ade80;
            background: rgba(74,222,128,0.08);
            border-color: rgba(74,222,128,0.14);
        }

            .ss-nav-item.active::before {
                content: '';
                position: absolute;
                left: 0;
                top: 22%;
                bottom: 22%;
                width: 3px;
                border-radius: 2px;
                background: #4ade80;
            }

    #ss-sidebar.docked .ss-nav-item {
        justify-content: center;
        padding: 10px;
    }

    .ss-nav-icon {
        width: 20px;
        text-align: center;
        font-size: .95rem;
        flex-shrink: 0;
    }

    .ss-nav-label {
        overflow: hidden;
        transition: opacity .2s, max-width .2s;
        max-width: 180px;
    }

    #ss-sidebar.docked .ss-nav-label {
        opacity: 0;
        max-width: 0;
    }

    /* Footer */
    .ss-footer {
        padding: 12px 8px;
        border-top: 1px solid rgba(255,255,255,0.07);
        flex-shrink: 0;
    }

    .ss-logout {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px 12px;
        border-radius: 10px;
        color: #f87171;
        font-family: 'DM Sans', sans-serif;
        font-size: .88rem;
        font-weight: 500;
        white-space: nowrap;
        cursor: pointer;
        text-decoration: none;
        transition: background .18s, color .18s;
        border: none;
        background: none;
        width: 100%;
    }

        .ss-logout:hover {
            background: rgba(248,113,113,0.08);
            color: #fca5a5;
        }

    #ss-sidebar.docked .ss-logout {
        justify-content: center;
        padding: 10px;
    }

        #ss-sidebar.docked .ss-logout .ss-nav-label {
            opacity: 0;
            max-width: 0;
        }
</style>

<aside id="ss-sidebar">

    <div class="ss-logo-row">
        <a href="/Home" class="ss-logo">Spend<span>Sense</span></a>
        <button class="ss-toggle" id="ss-toggle-btn" title="Toggle sidebar">
            <i class="fa-solid fa-bars"></i>
        </button>
    </div>

    <div class="ss-profile">
        @if (!string.IsNullOrEmpty(profileImage))
        {
            <img class="ss-avatar" src="~/images/profiles/@profileImage" alt="@fullName" />
        }
        else
        {
            <img class="ss-avatar" src="~/defaultprofile.jpg" alt="@fullName" />
        }
        <div class="ss-profile-info">
            <span class="ss-profile-name">@fullName</span>
            <span class="ss-profile-role">Personal Account</span>
        </div>
    </div>

    <nav class="ss-nav">
        <span class="ss-section-label">General</span>
        <a href="/Dashboard" class="ss-nav-item @ActiveIf("/dashboard")">
            <span class="ss-nav-icon"><i class="fa-solid fa-house"></i></span>
            <span class="ss-nav-label">Dashboard</span>
        </a>
        <a href="/Category" class="ss-nav-item @ActiveIf("/category")">
            <span class="ss-nav-icon"><i class="fa-solid fa-folder-closed"></i></span>
            <span class="ss-nav-label">Categories</span>
        </a>
        <a href="/Transaction" class="ss-nav-item @ActiveIf("/transaction")">
            <span class="ss-nav-icon"><i class="fa-solid fa-arrow-right-arrow-left"></i></span>
            <span class="ss-nav-label">Transactions</span>
        </a>

        <span class="ss-section-label" style="margin-top:8px;">Extras</span>
        <a href="/Reports" class="ss-nav-item @ActiveIf("/reports")">
            <span class="ss-nav-icon"><i class="fa-solid fa-chart-simple"></i></span>
            <span class="ss-nav-label">Reports</span>
        </a>
        <a href="/Settings" class="ss-nav-item @ActiveIf("/settings")">
            <span class="ss-nav-icon"><i class="fa-solid fa-gear"></i></span>
            <span class="ss-nav-label">Settings</span>
        </a>
        
    </nav>

    <div class="ss-footer">
        <a href="/Account/Logout" class="ss-logout">
            <span class="ss-nav-icon"><i class="fa-solid fa-right-from-bracket"></i></span>
            <span class="ss-nav-label">Logout</span>
        </a>
    </div>

</aside>

<script>
    (function () {
        const sidebar = document.getElementById('ss-sidebar');
        const btn = document.getElementById('ss-toggle-btn');
        const STORAGE_KEY = 'ss_sidebar_docked';
        if (localStorage.getItem(STORAGE_KEY) === '1') {
            sidebar.classList.add('docked');
            document.body.classList.add('sidebar-docked');
        }
        btn.addEventListener('click', () => {
            const isDocked = sidebar.classList.toggle('docked');
            document.body.classList.toggle('sidebar-docked', isDocked);
            localStorage.setItem(STORAGE_KEY, isDocked ? '1' : '0');
        });
    })();
</script>
