                        <div class="contact-info-item"><i class="fa-solid fa-envelope"></i> support@spendsense.in</div>
                        <div class="contact-info-item"><i class="fa-solid fa-phone"></i> +91 98765 43210</div>
                        <div class="contact-info-item"><i class="fa-solid fa-location-dot"></i> India</div>
                        <div class="contact-info-item"><i class="fa-solid fa-clock"></i> Mon – Fri, 9 AM – 6 PM IST</div>
                    </div>
                </div>

                <div class="contact-form reveal">
                    <div class="form-row">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text" placeholder="Rahul" />
                        </div>
                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text" placeholder="Sharma" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" placeholder="rahul@example.com" />
                    </div>
                    <div class="form-group">
                        <label>Subject</label>
                        <input type="text" placeholder="How can we help?" />
                    </div>
                    <div class="form-group">
