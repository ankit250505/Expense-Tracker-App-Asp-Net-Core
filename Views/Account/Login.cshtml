@{
}
@{
    Layout = "_LayoutLanding";
}
<section style="min-height:100vh; display:flex; align-items:center; justify-content:center;">

    ```
    <div class="hero-glow"></div>

    <div class="contact-form" style="width:100%; max-width:420px;">

        <div class="tag"><i class="fa-solid fa-lock"></i> Welcome Back</div>
        <h2 style="margin-bottom:10px;">Login to your account</h2>
        <p class="section-sub" style="margin-bottom:25px;">Enter your details to continue</p>

        <form method="post">
            <div class="form-group">
                <label>Email</label>
                <input name="email" type="email" placeholder="you@example.com" required />
            </div>

            <div class="form-group">
                <label>Password</label>
                <input name="password" type="password" placeholder="••••••••" required />
            </div>

            <button class="btn btn-primary" style="width:100%;justify-content:center;">
                Login <i class="fa-solid fa-arrow-right"></i>
            </button>
        </form>

        <p style="color:red; margin-top:10px;">@ViewBag.Error</p>

        <div style="text-align:center; margin-top:20px;">
            <span class="text-muted">Don't have an account?</span>
            <a href="/Account/Register" class="btn btn-ghost btn-sm">Register</a>
        </div>

    </div>
    ```

</section>
